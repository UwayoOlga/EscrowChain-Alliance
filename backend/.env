# ── Email / SMTP Configuration ──────────────────────────────────────
# Option A: Gmail (use an App Password, NOT your Google account password)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=youremail@gmail.com
#   SMTP_PASS=your-16-char-app-password
#
# Option B: Mailtrap (safe sandbox — no real emails sent, great for testing)
#   Sign up free at https://mailtrap.io → Inboxes → SMTP Settings
#   SMTP_HOST=sandbox.smtp.mailtrap.io
#   SMTP_PORT=2525
#   SMTP_SECURE=false
#   SMTP_USER=<mailtrap-user>
#   SMTP_PASS=<mailtrap-password>
#
# If these are blank, emails will be skipped silently (safe fallback)
