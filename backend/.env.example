# Session Security (REQUIRED)
SESSION_SECRET=your_very_long_random_session_secret_here_at_least_32_characters

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Option 1: SQLite (default - no configuration needed)
# Leave DATABASE_URL empty or commented out to use SQLite automatically

# Option 2: PostgreSQL (uncomment and configure)
# DATABASE_URL=postgresql://your_username:your_password@localhost:5432/blockrent_db